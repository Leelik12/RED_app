                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="ПРИОБРЕТЕНИЕ РЕПУТАЦИИ (За что знают)" Foreground="#FF3333" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1" Text="{Binding ReputationEvents, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="12" Background="#111111" BorderThickness="1" BorderBrush="#444444" Padding="4"
                                             TextWrapping="Wrap" AcceptsReturn="True" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="ОБРАЗ И СТИЛЬ" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                </Border>
                                        <TextBox Text="{Binding StyleNotes, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" Background="#111111" BorderBrush="#444444" FontSize="14" BorderThickness="1" AcceptsReturn="True" TextWrapping="Wrap" Margin="8,24,8,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="20*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="35*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="ЖИЛЬЕ" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Housing, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" Background="#111111" BorderBrush="#444444" BorderThickness="1" FontSize="14" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="АРЕНДНАЯ ПЛАТА" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Rent, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="14" Background="#111111" BorderBrush="#444444" BorderThickness="1" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="ОБРАЗ ЖИЗНИ" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Lifestyle, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="14" Background="#111111" BorderBrush="#444444" BorderThickness="1" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>
            </TabItem>

            <TabItem Header="СТР. 3: КИБЕРИМПЛАНТЫ">
                <Grid Margin="0,10,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CyberwareBlocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Background="#FF3333" Padding="6,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsInstalled, Mode=OneWay}" IsHitTestVisible="False" Style="{StaticResource NeonCheckBox}" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#050505" FontWeight="Heavy" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="14"/>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                                    <TextBlock Text="ЗАНЯТО:" Foreground="#050505" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                                                    <TextBox Text="{Binding UsedSlots, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Width="20" Height="18" Background="#050505" Foreground="#00FFCC" BorderThickness="0" TextAlignment="Center" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0" CaretBrush="Transparent" Padding="0"/>
                                                    <TextBlock Text="{Binding SlotsText, StringFormat='({0})'}" Foreground="#050505" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4">
                                            <StackPanel>
                                                <TextBox Text="{Binding OptionsText}" Foreground="#777777" FontSize="12" Background="Transparent" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" CaretBrush="#777777" Margin="0,0,0,5" ToolTip="Ручные заметки"/>

                                                <ItemsControl ItemsSource="{Binding InstalledItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#111111" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,4" Padding="4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" ToolTip="{Binding TooltipText}" ToolTipService.InitialShowDelay="150" Cursor="Help"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding Slots, StringFormat='Слотов: {0}'}" Foreground="#777777" FontSize="11" Margin="6,0" VerticalAlignment="Center"/>
                                                                    <Button Grid.Column="2" Content="X" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="Bold" Tag="{Binding}" Click="BtnUninstallCyber_Click" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>

                                        <Button Grid.Row="2" Content="УПРАВЛЕНИЕ ИМПЛАНТАМИ" Background="#111111" Foreground="#FF3333" BorderBrush="#FF3333" BorderThickness="1" Margin="6,2,6,6" Padding="0,4" Cursor="Hand" FontWeight="Bold" FontSize="11" Tag="{Binding}" Click="BtnOpenCyberwareManager_Click"/>
                                    </Grid>
                                </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Margin="0,0,5,0">
            <Button Cursor="Hand" Margin="0,0,10,0" Click="BtnSaveChanges_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="СОХРАНИТЬ" Foreground="#00FFCC" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Cursor="Hand" Click="BtnBackToMenu_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="ЗАКРЫТЬ ДОСЬЕ" Foreground="#FF3333" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        <Border x:Name="CyberwareOverlay" Background="#E5050505" Visibility="Collapsed" Panel.ZIndex="100" Margin="-15,-10,-15,-5">
            <Border Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Width="950" Height="700" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF3333" Padding="15,0">
                        <Grid>
                            <TextBlock Text="{Binding OverlayTitle}" Foreground="#050505" FontWeight="Heavy" FontSize="16" VerticalAlignment="Center"/>
                            <Button Content="X" Foreground="#050505" Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="BtnCloseCyberwareManager_Click"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#444444" BorderThickness="1" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="ДОСТУПНЫЕ ИМПЛАНТЫ" Foreground="#00FFCC" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding AvailableCyberware}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#111111" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,5" Padding="5" ToolTip="{Binding TooltipText}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding HumanityLoss, StringFormat='ПЧ: {0}'}" Foreground="#FF3333" FontSize="11"/>
                                                                <TextBlock Text="{Binding Slots, StringFormat='Слотов: {0}'}" Foreground="#999999" FontSize="11"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Content="X" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Margin="0,0,5,0" Padding="5" Cursor="Hand" FontWeight="Bold" FontSize="14" Tag="{Binding}" Click="BtnDeleteCustomCyber_Click">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="УСТАНОВИТЬ" Foreground="#00FFCC" Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="1" Padding="10,5" Cursor="Hand" Tag="{Binding}" Click="BtnInstallCyber_Click" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Padding="10" Margin="0,15,0,0">
                                <StackPanel>
                                    <TextBlock Text="СОЗДАТЬ СВОЙ ИМПЛАНТ" Foreground="#FF3333" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Название" Foreground="#999999" FontSize="11"/>
                                            <TextBox Text="{Binding NewCyberName, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" Padding="2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Зависимость (Базовый имплант)" Foreground="#999999" FontSize="11"/>
                                            <ComboBox ItemsSource="{Binding AvailableRequires}" SelectedItem="{Binding NewCyberRequires, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#00FFCC" BorderBrush="#444444" BorderThickness="1" Height="22"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Эффект / Описание" Foreground="#999999" FontSize="11"/>
                                    <TextBox Text="{Binding NewCyberDesc, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" Margin="0,0,0,5" Height="30" AcceptsReturn="True" TextWrapping="Wrap" Padding="2"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="15"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ПЧ (Напр. 2d6)" Foreground="#999999" FontSize="11"/>
                                            <TextBox Text="{Binding NewCyberHL, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#FF3333" BorderBrush="#444444" BorderThickness="1" Padding="2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Слотов" Foreground="#999999" FontSize="11"/>
                                            <TextBox Text="{Binding NewCyberSlots, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Background="#050505" Foreground="#00FFCC" BorderBrush="#444444" BorderThickness="1" Padding="2"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                            <CheckBox IsChecked="{Binding NewCyberIsFoundation}" Content="Базовый имплант (разъем для других)" Foreground="#E0E0E0" FontSize="11" Margin="0,0,0,4" Style="{StaticResource NeonCheckBox}"/>
                                            <CheckBox IsChecked="{Binding NewCyberIsPaired}" Content="Парный имплант (в обе руки/глаза)" Foreground="#E0E0E0" FontSize="11" Style="{StaticResource NeonCheckBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border BorderBrush="#333333" BorderThickness="1" Padding="5" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="ВЛИЯНИЕ НА НАВЫКИ" Foreground="#00FFCC" FontWeight="Bold" FontSize="11" Margin="0,0,0,5"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ComboBox Grid.Column="0" ItemsSource="{Binding AllSkillNames}" SelectedItem="{Binding SelectedSkillForMod, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" Height="22"/>
                                                <ComboBox Grid.Column="2" ItemsSource="{Binding AllModTypes}" SelectedItem="{Binding SelectedTypeForMod, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" Height="22"/>
                                                <TextBox Grid.Column="4" Text="{Binding SelectedValueForMod, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBoxWithMinus" TextChanged="NumberLimitFromMinus777To777_TextChanged" Background="#050505" Foreground="#00FFCC" BorderBrush="#444444" BorderThickness="1" TextAlignment="Center" Height="22"/>
                                                <Button Grid.Column="6" Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnAddCustomMod_Click"/>
                                            </Grid>

                                            <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                                                <ItemsControl ItemsSource="{Binding NewCyberModifiers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Foreground="#E0E0E0" FontSize="11">
                                                                    <Run Text="{Binding SkillName}"/>
                                                                    <Run Text="[" Foreground="#777777"/><Run Text="{Binding ModType}" Foreground="#777777"/><Run Text="]" Foreground="#777777"/>
                                                                    <Run Text=": "/><Run Text="{Binding Value}" Foreground="#00FFCC" FontWeight="Bold"/>
                                                                </TextBlock>
                                                                <Button Grid.Column="1" Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveCustomMod_Click"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="ДОБАВИТЬ В БАЗУ" Background="#FF3333" Foreground="#050505" FontWeight="Bold" FontSize="14" Padding="5" Cursor="Hand" Click="BtnCreateCustomCyber_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="УСТАНОВЛЕНО В БЛОК" Foreground="#00FFCC" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding CurrentCyberBlock.InstalledItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="1" Margin="0,0,0,5" Padding="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Slots, StringFormat='Слотов: {0}'}" Foreground="#00FFCC" FontSize="11"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="УДАЛИТЬ" Foreground="#FF3333" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10,5" Cursor="Hand" Tag="{Binding}" Click="BtnUninstallCyber_Click" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
        </Grid>
    </Viewbox>
</Window>