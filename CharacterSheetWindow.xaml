<Window x:Class="CyberpunkRED_Generator.CharacterSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ТЕРМИНАЛ ПЕРСОНАЖА" Height="1080" Width="1920" Background="#050505" WindowState="Maximized" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <Style x:Key="TinyRoleBtn" TargetType="Button">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="BorderBrush" Value="#00FFCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,-2,0,0"/>
        </Style>
        <Style x:Key="NeonCheckBox" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                            <Grid VerticalAlignment="Center" Width="16" Height="16">
                                <Border x:Name="Border" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A"/>
                                <Path x:Name="CheckMark" Data="M 3 8 L 6 12 L 13 3" Stroke="#00FFCC" StrokeThickness="3" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00FFCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Panel" Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Margin="0,0,5,0" Padding="25,12" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" TextElement.Foreground="#00FFCC" TextElement.FontWeight="Bold" TextElement.FontSize="16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#FF3333"/>
                                <Setter Property="TextElement.Foreground" Value="#050505"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RedHeader" TargetType="Border">
            <Setter Property="Background" Value="#FF3333"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="RedHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SkillBox" TargetType="Border">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FF3333" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF3333"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#050505"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF3333"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#050505"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="#00FFCC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" TextElement.Foreground="{TemplateBinding Foreground}" Margin="6,0,20,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border Background="#0A0A0A" BorderThickness="1" BorderBrush="#FF3333"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Viewbox Stretch="Fill">
        <Grid Width="1920" Height="1080">
            <Grid Margin="15,10,15,5">

        <TabControl x:Name="SheetTabControl">
            <TabItem Header="СТР. 1: ХАРАКТЕРИСТИКИ И НАВЫКИ">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2.5*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="0.6*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                            <TextBlock Text="PORTRAIT" Foreground="#FF3333" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                <TextBlock Text="ИМЯ" Style="{StaticResource RedHeaderText}"/>
                            </Border>
                                    <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,0">
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                         Foreground="#00FFCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"
                                         Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                    </Border>
                                </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                <TextBlock Text="РОЛЬ" Style="{StaticResource RedHeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,4">
                                <TextBlock Text="{Binding Role}" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                                <Grid Grid.Row="3" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="55"/>
                                    </Grid.ColumnDefinitions>

                                    <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                        <Grid>
                                            <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                                <TextBlock Text="{Binding Role, StringFormat='СПОСОБНОСТЬ: {0}'}" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                            </Border>

                                            <Grid Visibility="{Binding IsTextRoleVis}" Margin="4,24,4,4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="50"/>
                                                </Grid.RowDefinitions>

                                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding RoleDescription}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="4,0,4,0"/>
                                                </ScrollViewer>

                                                <TextBlock Grid.Row="1" Text="ЛИЧНЫЕ ЗАМЕТКИ:" Foreground="#FF3333" FontSize="10" FontWeight="Bold"/>
                                                <TextBox Grid.Row="2" Text="{Binding RoleAbilityNotes, UpdateSourceTrigger=PropertyChanged}" 
                                                 Foreground="#E0E0E0" FontSize="13" Background="#111111" BorderThickness="1" BorderBrush="#333333" Padding="2"
                                                 TextWrapping="Wrap" AcceptsReturn="True" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                                            </Grid>

                                            <StackPanel Visibility="{Binding IsSoloVis}" Margin="4,24,4,4">
                                                <TextBlock Text="{Binding SoloPointsText}" Foreground="#FF3333" FontSize="11" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Обнаружение угрозы (1)" ToolTip="Каждое очко даёт +1 ко всем проверкам навыка Внимательность." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Threat" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloThreat}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Threat" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Оценка ситуации (1)" ToolTip="Каждое очко даёт +1 к урону (до учёта брони) первой успешной атаки за раунд." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Awareness" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloAwareness}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Awareness" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Снижение урона (2)" ToolTip="Уменьшает первый урон в раунде. За 2 очка: -1. За 4 очка: -2. За 6: -3. За 8: -4. За 10: -5." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Deflection" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloDeflection}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Deflection" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Компенсация провала (1)" ToolTip="За 4 очка игнорирует критические провалы (выпавшие 1) при атаке (считается просто как 1)." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Fumble" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloFumble}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Fumble" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Моментальная реакция (1)" ToolTip="Каждое очко даёт +1 ко всем броскам Инициативы." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Initiative" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloInitiative}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Initiative" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Точная атака (3)" ToolTip="За 3 очка: +1 ко всем атакам. За 6 очков: +2. За 9 очков: +3." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="Precision" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding SoloPrecision}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="Precision" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding IsTechVis}" Margin="4,24,4,4">
                                                <TextBlock Text="{Binding TechPointsText}" Foreground="#FF3333" FontSize="11" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Полевая экспертиза (1)" ToolTip="Добавляет ранг ко всем Техническим навыкам. Позволяет временно починить предмет (аварийный ремонт) на 10 мин за ранг." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="TechField" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding TechField}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="TechField" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Улучшение (1)" ToolTip="Улучшает предмет (снизить ПЧ, добавить слот, скрыть оружие, повысить качество). Требует материалы той же цены." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="TechUpgrade" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding TechUpgrade}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="TechUpgrade" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Производство (1)" ToolTip="Изготовление предмета по категории цены на 1 уровень ниже рыночной." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="TechFab" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding TechFab}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="TechFab" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Изобретение (1)" ToolTip="Создание новых модификаций и уникальных предметов совместно с рефери." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="-" Tag="TechInvent" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding TechInvent}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="TechInvent" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Visibility="{Binding IsMedtechVis}" Margin="4,24,4,4">
                                                <TextBlock Text="{Binding MedtechPointsText}" Foreground="#FF3333" FontSize="11" FontWeight="Bold" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Хирургия (1)" ToolTip="Позволяет лечить самые тяжёлые критические травмы и устанавливать киберимпланты." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MedSurgeryTotal, StringFormat='[ИТОГ: {0}]'}" Foreground="#777777" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Tag="MedSurgery" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding MedSurgery}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="MedSurgery" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Фармацевтика (1)" ToolTip="Синтез препаратов: Антибиотики, Детокс, Всплеск, Спидхил, Стим. Требует материалы на 200eb." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding MedPharmaTotal, StringFormat='[ИТОГ: {0}]'}" Foreground="#777777" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Tag="MedPharma" Click="BtnRoleMinus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                        <TextBlock Text="{Binding MedPharma}" Width="20" TextAlignment="Center" Foreground="#00FFCC" FontSize="12" FontWeight="Bold"/>
                                                        <Button Content="+" Tag="MedPharma" Click="BtnRolePlus_Click" Style="{StaticResource TinyRoleBtn}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Опер. криосистем (1)" ToolTip="Уровень 1: крионасос. Уровни 2+: доступ к корпоративным криокамерам, получение личных криокамер." Cursor="Help" Foreground="#E0E0E0" FontSize="11" VerticalAlignment="Center"/>
