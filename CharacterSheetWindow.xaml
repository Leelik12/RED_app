                                                <Border BorderBrush="#444444" BorderThickness="0,0,0,1" Padding="2" ToolTip="{Binding TooltipText}" ToolTipService.InitialShowDelay="150">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="#FF3333" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Cursor="Hand" FontWeight="Bold" FontSize="12" Click="BtnRemoveInjury_Click" Padding="4,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Height="65">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="ЗАВИСИМОСТИ" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                </Border>
                                        <TextBox Text="{Binding Addictions, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="13" Background="#111111" BorderBrush="#444444" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True" Margin="4,24,4,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.8*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="БРОНЯ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ДЕТАЛЬ" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="ОС" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="ШТРАФ" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита головы" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.HeadSp, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.HeadPenalty, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита туловища" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.BodySp, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.BodyPenalty, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Щит" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.ShieldSp, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.ShieldPenalty, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimit777_TextChanged" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Штрафы брони применяются к РЕА, ЛВК и СКО" Foreground="#FF3333" FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="ОРУЖИЕ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="4.0*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ОРУЖИЕ" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                                        <TextBlock Grid.Column="1" Text="УРОН" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="БОЕПР." Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="ROF" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="ЗАМЕТКИ" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Weapons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="26">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.5*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="4.0*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Margin="2,0" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Damage, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Ammo, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="3" Text="{Binding Rof, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="4" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Margin="2,0" CaretBrush="#00FFCC"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="СТР. 2: БИОГРАФИЯ И СВЯЗИ">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2.2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,0" Padding="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource RedHeader}" BorderThickness="2" Margin="0,0,0,10">
                                <TextBlock Text="ДОСЬЕ ПЕРСОНАЖА" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Center"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="ЖИЗНЕННЫЙ ПУТЬ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,5,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Lifepath}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Key}" Foreground="#999999" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                    <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6">
                                                        <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                                    <TextBlock Text="РОЛЕВОЙ ПУТЬ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding RoleLifepath}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Key}" Foreground="#FF3333" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                    <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10,6">
                                                        <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                                    <TextBlock Text="СОЦИАЛЬНЫЕ СВЯЗИ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,0,0,10"/>

                                    <TextBlock Text="ДРУЗЬЯ" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" Margin="2,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding Friends}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="ТРАГИЧЕСКИЕ РОМАНЫ" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" Margin="2,12,0,5"/>
                                    <ItemsControl ItemsSource="{Binding TragicLoves}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="ВРАГИ" Foreground="#FF3333" FontSize="13" FontWeight="Bold" Margin="2,12,0,5"/>
                                    <ItemsControl ItemsSource="{Binding Enemies}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Who}" Foreground="#FF3333" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding Cause, StringFormat='Причина: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Hate, StringFormat='Уровень: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Action, StringFormat='План: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="6.0*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="1.2*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="1.5*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="1.0*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="СНАРЯЖЕНИЕ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>

                                <Border Grid.Row="1" Background="#000000" Height="26" Margin="0,24,0,0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="СНАРЯЖЕНИЕ" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock Grid.Column="1" Text="ЗАМЕТКИ" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        <Button Grid.Column="1" Content="+" Foreground="#050505" Background="#00FFCC" BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20" FontWeight="Bold" Cursor="Hand" Click="BtnAddGear_Click" ToolTip="Добавить пустую строку снаряжения"/>
                                    </Grid>
                                </Border>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding GearItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="24">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Padding="8,0,2,0" CaretBrush="#00FFCC"/>
                                                    <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Padding="6,0,2,0" CaretBrush="#00FFCC"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Grid.Row="3" BorderBrush="#333333" BorderThickness="0,1,0,1" Height="28">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#000000" Padding="10,0,0,0">
                                            <TextBlock Text="БОЕПРИПАСЫ" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                        <TextBox Grid.Column="2" Text="{Binding AmmoValue, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Padding="6,0,0,0" CaretBrush="#00FFCC"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="4" Height="28">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#000000" Padding="10,0,0,0">
                                            <TextBlock Text="НАЛИЧНЫЕ" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                        <TextBox Grid.Column="2" Text="{Binding CashValue, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Padding="6,0,0,0" CaretBrush="#00FFCC"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
