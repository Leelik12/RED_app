                                <Border Grid.Row="0" Style="{StaticResource RedHeader}" HorizontalAlignment="Stretch" BorderThickness="0,0,2,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="КРИТ. ТРАВМЫ" Style="{StaticResource RedHeaderText}" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center"/>
