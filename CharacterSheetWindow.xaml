<Window x:Class="CyberpunkRED_Generator.CharacterSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЛИСТ ПЕРСОНАЖА (ОФИЦИАЛЬНЫЙ ФОРМАТ)" Height="1000" Width="1450" Background="#050505" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Panel" Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Margin="0,0,5,0" Padding="25,12" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" TextElement.Foreground="#00FFCC" TextElement.FontWeight="Bold" TextElement.FontSize="16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#FF3333"/>
                                <Setter Property="TextElement.Foreground" Value="#050505"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedHeader" TargetType="Border">
            <Setter Property="Background" Value="#FF3333"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="RedHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SkillBox" TargetType="Border">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FF3333" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00D4B2"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        Padding="{TemplateBinding Padding}"
                        CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">

        <TabControl x:Name="SheetTabControl">
            <TabItem Header="СТР. 1: ХАРАКТЕРИСТИКИ И НАВЫКИ">

                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="3.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="2.4*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="180"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1.5*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1.2*"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                                <TextBlock Text="PORTRAIT" Foreground="#FF3333" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                    <TextBlock Text="HANDLE" Style="{StaticResource RedHeaderText}"/>
                                </Border>
                                <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,4">
                                    <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                    <TextBlock Text="ROLE" Style="{StaticResource RedHeaderText}"/>
                                </Border>
                                <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,4">
                                    <TextBlock Text="{Binding Role}" Foreground="#00FFCC" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="45"/>
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                    <Grid>
                                        <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                            <TextBlock Text="ROLE ABILITY" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{Binding Role}" Foreground="#00FFCC" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1" Background="#FF3333" Margin="4,0,0,0">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="RANK" Foreground="#050505" FontWeight="Heavy" FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock Text="4" Foreground="#050505" FontWeight="Heavy" FontSize="22" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                        <TextBlock Text="NOTES" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                    </Border>
                                    <TextBlock Text="Связано с досье на вкладке 2" Foreground="#555555" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="5" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                    <TextBlock Text="HUMANITY" Style="{StaticResource RedHeaderText}"/>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4">
                                    <TextBlock Text="{Binding SystemStats[Humanity]}" Foreground="#00FFCC" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="6" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2,2,1,2" Background="#0A0A0A">
                                    <StackPanel>
                                        <Border Background="#FF3333">
                                            <TextBlock Text="HP" Foreground="#050505" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" Padding="2"/>
                                        </Border>
                                        <TextBlock Text="{Binding SystemStats[HP]}" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#FF3333" BorderThickness="1,2,1,2" Background="#0A0A0A">
                                    <StackPanel>
                                        <Border Background="#FF3333">
                                            <TextBlock Text="WOUNDED" Foreground="#050505" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" Padding="2"/>
                                        </Border>
                                        <TextBlock Text="{Binding SystemStats[WoundedThreshold]}" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="1,2,2,2" Background="#0A0A0A">
                                    <StackPanel>
                                        <Border Background="#FF3333">
                                            <TextBlock Text="D. SAVE" Foreground="#050505" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" Padding="2"/>
                                        </Border>
                                        <TextBlock Text="{Binding SystemStats[DeathSave]}" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Grid.Row="7" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                        <TextBlock Text="CRITICAL INJURIES" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Row="8" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                        <TextBlock Text="ADDICTIONS" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="4">
                            <ItemsControl ItemsSource="{Binding HexStats}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Margin="0,2">
                                            <StackPanel VerticalAlignment="Center">
                                                <Border Background="#FF3333" Padding="2">
                                                    <TextBlock Text="{Binding Name}" Foreground="#050505" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding Value}" Foreground="#00FFCC" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Padding="0,5"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Column="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4">
                            <ItemsControl ItemsSource="{Binding CenterSkillCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,4">
                                            <Border BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="38"/>
                                                    <ColumnDefinition Width="38"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="3" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Skills}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1.5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="38"/>
                                                                <ColumnDefinition Width="38"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click"
                                                                        Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>

                                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>

                                                                <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>

                                                                <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" 
                                                                           Background="Transparent" Foreground="#00FFCC" BorderThickness="0" CaretBrush="#00FFCC"
                                                                           Width="300" FontSize="15" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>

                                                                <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click"
                                                                        Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                                <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="14" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                            </Border>

                                                            <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                                <TextBlock Text="{Binding StatValue}" Foreground="#AAAAAA" TextAlignment="Center" FontSize="13" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Grid.Column="3" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                                <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Column="6" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4">
                            <ItemsControl ItemsSource="{Binding RightSkillCategories1}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,4">
                                            <Border BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="38"/>
                                                    <ColumnDefinition Width="38"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="3" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Skills}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1.5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="38"/>
                                                                <ColumnDefinition Width="38"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click"
                                                                        Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                                <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                                <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" 
                                                                           Background="Transparent" Foreground="#00FFCC" BorderThickness="0" CaretBrush="#00FFCC"
                                                                           Width="300" FontSize="15" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                                <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click"
                                                                        Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                                <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="14" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                            </Border>
                                                            <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                                <TextBlock Text="{Binding StatValue}" Foreground="#AAAAAA" TextAlignment="Center" FontSize="13" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Grid.Column="3" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                                <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <Border Grid.Column="8" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4">
                            <ItemsControl ItemsSource="{Binding RightSkillCategories2}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,4">
                                            <Border BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>

                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="38"/>
                                                    <ColumnDefinition Width="38"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="3" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Skills}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1.5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="38"/>
                                                                <ColumnDefinition Width="38"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click"
                                                                        Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                                <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" 
                                                                           Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                                <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" 
                                                                         Background="#111111" Foreground="#00FFCC" BorderBrush="#00FFCC" BorderThickness="0,0,0,1" 
                                                                         Width="70" FontSize="14" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                                <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" 
                                                                        Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click"
                                                                        Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                                <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="14" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                            </Border>
                                                            <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                                <TextBlock Text="{Binding StatValue}" Foreground="#AAAAAA" TextAlignment="Center" FontSize="13" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Grid.Column="3" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                                <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="ARMOR" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ДЕТАЛЬ" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="SP" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="ШТРАФ" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита головы" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита туловища" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Щит" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBlock Text="—" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Штрафы брони применяются к РЕА, ЛВК и СКО" Foreground="#FF3333" FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="WEAPONS" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ОРУЖИЕ" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="УРОН" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="AMMO" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="ROF" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="ЗАМЕТКИ" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                    </Grid>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="22"/>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="22"/>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="22"/>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="22"/>
                                    <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="22"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="СТР. 2: БИОГРАФИЯ И СВЯЗИ">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#333333" BorderThickness="0,0,1,0" Margin="0,0,10,0" Padding="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2" Margin="0,0,0,10">
                                <TextBlock Text="ЖИЗНЕННЫЙ ПУТЬ" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Center"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Lifepath}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Key}" Foreground="#999999" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6">
                                                    <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#333333" BorderThickness="0,0,1,0" Margin="0,0,10,0" Padding="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2" Margin="0,0,0,10">
                                <TextBlock Text="РОЛЕВОЙ ПУТЬ" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Center"/>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RoleLifepath}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding Key}" Foreground="#FF3333" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10,6">
                                                    <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource RedHeader}" BorderThickness="2" Margin="0,0,0,10">
                            <TextBlock Text="СОЦИАЛЬНЫЕ СВЯЗИ" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Center"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="ДРУЗЬЯ" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" Margin="2,0,0,5"/>
                                <ItemsControl ItemsSource="{Binding Friends}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="ТРАГИЧЕСКИЕ РОМАНЫ" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" Margin="2,15,0,5"/>
                                <ItemsControl ItemsSource="{Binding TragicLoves}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="ВРАГИ" Foreground="#FF3333" FontSize="15" FontWeight="Bold" Margin="2,15,0,5"/>
                                <ItemsControl ItemsSource="{Binding Enemies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Who}" Foreground="#FF3333" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding Cause, StringFormat='Причина: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding Hate, StringFormat='Уровень: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding Action, StringFormat='План: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Margin="0,0,5,0">
            <Button Cursor="Hand" Margin="0,0,10,0" Click="BtnSaveChanges_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="[ ~ ] СОХРАНИТЬ" Foreground="#00FFCC" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Cursor="Hand" Click="BtnBackToMenu_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="[ X ] ЗАКРЫТЬ ДОСЬЕ" Foreground="#FF3333" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>