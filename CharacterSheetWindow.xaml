<Window x:Class="CyberpunkRED_Generator.CharacterSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЛИСТ ПЕРСОНАЖА (ОФИЦИАЛЬНЫЙ ФОРМАТ)" Height="1000" Width="1450" Background="#050505" WindowState="Maximized" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Panel" Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Margin="0,0,5,0" Padding="25,12" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" TextElement.Foreground="#00FFCC" TextElement.FontWeight="Bold" TextElement.FontSize="16"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#FF3333"/>
                                <Setter Property="TextElement.Foreground" Value="#050505"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedHeader" TargetType="Border">
            <Setter Property="Background" Value="#FF3333"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="RedHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SkillBox" TargetType="Border">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="1,0"/>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FF3333" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15,10,15,5">

        <TabControl x:Name="SheetTabControl">
            <TabItem Header="СТР. 1: ХАРАКТЕРИСТИКИ И НАВЫКИ">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2.0*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="3.2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2.5*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                            <TextBlock Text="PORTRAIT" Foreground="#FF3333" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                <TextBlock Text="ИМЯ" Style="{StaticResource RedHeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,4">
                                <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                <TextBlock Text="РОЛЬ" Style="{StaticResource RedHeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Padding="8,4">
                                <TextBlock Text="{Binding Role}" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="45"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="{Binding Role, StringFormat='СПОСОБНОСТЬ: {0}'}" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                    </Border>
                                    <TextBox Text="{Binding RoleAbilityNotes, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="13" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" Margin="4,24,4,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Background="#FF3333" Margin="4,0,0,0">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="РАНГ" Foreground="#050505" FontWeight="Heavy" FontSize="12" HorizontalAlignment="Center"/>
                                    <TextBlock Text="4" Foreground="#050505" FontWeight="Heavy" FontSize="22" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="0,0,0,6">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="ЗАМЕТКИ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="13" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" Margin="4,24,4,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="5" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource RedHeader}" BorderThickness="2,2,0,2">
                                <TextBlock Text="ЧЕЛОВЕЧНОСТЬ" Style="{StaticResource RedHeaderText}"/>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBox Text="{Binding CurrentHumanity, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="20" FontWeight="Bold" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC" TextAlignment="Right" MinWidth="25"/>
                                    <TextBlock Text="/" Foreground="#00FFCC" FontSize="20" FontWeight="Bold" Margin="4,0"/>
                                    <TextBox Text="{Binding MaxHumanity, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="20" FontWeight="Bold" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC" TextAlignment="Left" MinWidth="25"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="6" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2,2,1,2" Background="#0A0A0A">
                                <StackPanel>
                                    <Border Background="#FF3333">
                                        <TextBlock Text="ПЗ" Foreground="#050505" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Padding="2"/>
                                    </Border>
                                    <TextBlock Text="{Binding SystemStats[HP]}" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#FF3333" BorderThickness="1,2,1,2" Background="#0A0A0A">
                                <StackPanel>
                                    <Border Background="#FF3333">
                                        <TextBlock Text="ТЯЖ. РАНЕНИЕ" Foreground="#050505" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Padding="2"/>
                                    </Border>
                                    <TextBlock Text="{Binding SystemStats[WoundedThreshold]}" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="1,2,2,2" Background="#0A0A0A">
                                <StackPanel>
                                    <Border Background="#FF3333">
                                        <TextBlock Text="ИСП. СМЕРТИ" Foreground="#050505" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Padding="2"/>
                                    </Border>
                                    <TextBlock Text="{Binding SystemStats[DeathSave]}" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="0" Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="4" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding HexStats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Margin="0,2" ToolTip="{Binding TooltipText}" ToolTipService.InitialShowDelay="150">
                                        <StackPanel VerticalAlignment="Center">
                                            <Border Background="#FF3333" Padding="2">
                                                <TextBlock Text="{Binding Name}" Foreground="#050505" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <Grid Margin="0,5">
                                                <TextBlock x:Name="SingleStat" Text="{Binding CurrentValue}" Foreground="#00FFCC" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <StackPanel x:Name="FractionalStat" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                                                    <TextBox Text="{Binding CurrentValue, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="24" FontWeight="Bold" Background="Transparent" BorderThickness="0" IsReadOnly="{Binding IsReadOnly}" CaretBrush="#00FFCC" MinWidth="18" TextAlignment="Right"/>
                                                    <TextBlock Text="/" Foreground="#00FFCC" FontSize="24" FontWeight="Bold" Margin="2,0"/>
                                                    <TextBlock Text="{Binding BaseValue}" Foreground="#00FFCC" FontSize="24" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsFractional}" Value="True">
                                            <Setter TargetName="SingleStat" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="FractionalStat" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding CenterSkillCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">
                                        <Border BorderBrush="#00FFCC" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="3" Text="ДОП" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="4" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Skills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="36"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click" Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" Background="Transparent" Foreground="#00FFCC" BorderThickness="0" CaretBrush="#00FFCC" Width="120" FontSize="15" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                            <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click" Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                            <TextBlock Text="{Binding StatValue}" Foreground="#E0E0E0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold"/>
                                                        </Border>
                                                        <Border Grid.Column="3" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Modifier, UpdateSourceTrigger=PropertyChanged}" Foreground="#999999" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="4" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                            <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="15" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="6" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding RightSkillCategories1}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">
                                        <Border BorderBrush="#00FFCC" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="3" Text="ДОП" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="4" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Skills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="36"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click" Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" Background="Transparent" Foreground="#00FFCC" BorderThickness="0" CaretBrush="#00FFCC" Width="220" FontSize="15" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                            <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click" Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                            <TextBlock Text="{Binding StatValue}" Foreground="#E0E0E0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold"/>
                                                        </Border>
                                                        <Border Grid.Column="3" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Modifier, UpdateSourceTrigger=PropertyChanged}" Foreground="#999999" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="4" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                            <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="15" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="8" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8,4" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding RightSkillCategories2}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,4">
                                        <Border BorderBrush="#00FFCC" BorderThickness="1" Background="#111111" Padding="4,2" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="36"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="1" Text="УР" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="2" Text="СТАТ" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="3" Text="ДОП" Foreground="#777777" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="4" Text="СУМ" Foreground="#FF3333" FontSize="11" TextAlignment="Center" FontWeight="Bold"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Skills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="36"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Visibility="{Binding RemoveBtnVis}" Tag="{Binding}" Click="BtnRemoveVariant_Click" Margin="0,0,4,0" Padding="0" Cursor="Hand" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseNameVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBlock Text="{Binding BaseName, StringFormat='{}{0}: '}" Foreground="#E0E0E0" FontSize="15" VerticalAlignment="Center" Visibility="{Binding BaseVariantLabelVis}" ToolTip="{Binding Description}" ToolTipService.InitialShowDelay="200" ToolTipService.ShowDuration="15000"/>
                                                            <TextBox Text="{Binding SubName, UpdateSourceTrigger=PropertyChanged}" Visibility="{Binding SubNameVis}" Background="Transparent" Foreground="#00FFCC" BorderThickness="0" CaretBrush="#00FFCC" Width="120" FontSize="15" Padding="0" Margin="0" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                            <Button Content="+" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" Visibility="{Binding AddBtnVis}" Tag="{Binding}" Click="BtnAddVariant_Click" Margin="6,0,0,0" Padding="0" Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Level, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="2" Style="{StaticResource SkillBox}">
                                                            <TextBlock Text="{Binding StatValue}" Foreground="#E0E0E0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold"/>
                                                        </Border>
                                                        <Border Grid.Column="3" Style="{StaticResource SkillBox}">
                                                            <TextBox Text="{Binding Modifier, UpdateSourceTrigger=PropertyChanged}" Foreground="#999999" Background="Transparent" BorderThickness="0" TextAlignment="Center" FontSize="15" VerticalAlignment="Center" FontWeight="Bold" FontFamily="Consolas"/>
                                                        </Border>
                                                        <Border Grid.Column="4" Background="#050505" BorderBrush="#FF3333" BorderThickness="1" Margin="1,0">
                                                            <TextBlock Text="{Binding Base}" Foreground="#00FFCC" FontWeight="Bold" TextAlignment="Center" FontSize="15" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>


                    <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="КРИТ. ТРАВМЫ" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                </Border>
                                <TextBox Text="{Binding CriticalInjuries, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="13" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" Margin="4,24,4,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Height="65">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="ЗАВИСИМОСТИ" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                </Border>
                                <TextBox Text="{Binding Addictions, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="13" Background="Transparent" BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True" Margin="4,24,4,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.8*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="БРОНЯ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ДЕТАЛЬ" Foreground="#888888" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Grid.Column="1" Text="ОС" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="ШТРАФ" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита головы" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.HeadSp, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.HeadPenalty, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Защита туловища" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.BodySp, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.BodyPenalty, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <Grid Margin="0,2" Height="25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Щит" Foreground="#FFFFFF" FontSize="13" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.ShieldSp, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                        <Border Grid.Column="2" BorderBrush="#444444" BorderThickness="1" Margin="2,0">
                                            <TextBox Text="{Binding Armor.ShieldPenalty, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" CaretBrush="#00FFCC"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="Штрафы брони применяются к РЕА, ЛВК и СКО" Foreground="#FF3333" FontSize="11" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Padding="8">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2">
                                    <TextBlock Text="ОРУЖИЕ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>
                                <StackPanel Margin="0,35,0,0">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="4.0*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ОРУЖИЕ" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                                        <TextBlock Grid.Column="1" Text="УРОН" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="БОЕПР." Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="ROF" Foreground="#888888" FontSize="12" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="ЗАМЕТКИ" Foreground="#888888" FontSize="12" FontWeight="Bold" Margin="4,0,0,0"/>
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Weapons}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="26">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.5*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="4.0*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Margin="2,0" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Damage, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="2" Text="{Binding Ammo, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="3" Text="{Binding Rof, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" TextAlignment="Center" CaretBrush="#00FFCC"/>
                                                        <TextBox Grid.Column="4" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Margin="2,0" CaretBrush="#00FFCC"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="СТР. 2: БИОГРАФИЯ И СВЯЗИ">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="2.2*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,0" Padding="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource RedHeader}" BorderThickness="2" Margin="0,0,0,10">
                                <TextBlock Text="ДОСЬЕ ПЕРСОНАЖА" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Center"/>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,5,0">
                                    <TextBlock Text="ЖИЗНЕННЫЙ ПУТЬ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,5,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Lifepath}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Key}" Foreground="#999999" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                    <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6">
                                                        <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                                    <TextBlock Text="РОЛЕВОЙ ПУТЬ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding RoleLifepath}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding Key}" Foreground="#FF3333" FontSize="12" FontWeight="Bold" Margin="2,0,0,2"/>
                                                    <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10,6">
                                                        <TextBlock Text="{Binding Value}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

                                    <TextBlock Text="СОЦИАЛЬНЫЕ СВЯЗИ" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="2,0,0,10"/>

                                    <TextBlock Text="ДРУЗЬЯ" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" Margin="2,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding Friends}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="ТРАГИЧЕСКИЕ РОМАНЫ" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" Margin="2,12,0,5"/>
                                    <ItemsControl ItemsSource="{Binding TragicLoves}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#444444" BorderThickness="1" Padding="10,6" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding}" Foreground="#FFFFFF" FontSize="14" TextWrapping="Wrap"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="ВРАГИ" Foreground="#FF3333" FontSize="13" FontWeight="Bold" Margin="2,12,0,5"/>
                                    <ItemsControl ItemsSource="{Binding Enemies}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Who}" Foreground="#FF3333" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding Cause, StringFormat='Причина: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Hate, StringFormat='Уровень: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                                                        <TextBlock Text="{Binding Action, StringFormat='План: {0}'}" Foreground="#E0E0E0" FontSize="13" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="6.0*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="1.0*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="СНАРЯЖЕНИЕ" Style="{StaticResource RedHeaderText}" FontSize="12"/>
                                </Border>

                                <Border Grid.Row="1" Background="#000000" Height="26" Margin="0,24,0,0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="СНАРЯЖЕНИЕ" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <TextBlock Grid.Column="1" Text="ЗАМЕТКИ" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                </Border>

                                <ItemsControl Grid.Row="2" ItemsSource="{Binding GearItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#333333" BorderThickness="0,0,0,1" Height="24">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Padding="8,0,2,0" CaretBrush="#00FFCC"/>
                                                    <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" Padding="6,0,2,0" CaretBrush="#00FFCC"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Grid.Row="3" BorderBrush="#333333" BorderThickness="0,1,0,1" Height="28">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#000000" Padding="10,0,0,0">
                                            <TextBlock Text="БОЕПРИПАСЫ" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                        <TextBox Grid.Column="2" Text="{Binding AmmoValue, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Padding="6,0,0,0" CaretBrush="#00FFCC"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="4" Height="28">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#000000" Padding="10,0,0,0">
                                            <TextBlock Text="НАЛИЧНЫЕ" Foreground="#FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#333333" Width="1" VerticalAlignment="Stretch"/>
                                        <TextBox Grid.Column="2" Text="{Binding CashValue, UpdateSourceTrigger=PropertyChanged}" Foreground="#00FFCC" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Padding="6,0,0,0" CaretBrush="#00FFCC"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                            <Grid>
                                <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                    <TextBlock Text="ОБРАЗ И СТИЛЬ" Style="{StaticResource RedHeaderText}" FontSize="11"/>
                                </Border>
                                <TextBox Text="{Binding StyleNotes, UpdateSourceTrigger=PropertyChanged}" Foreground="#E0E0E0" FontSize="14" Background="Transparent" BorderThickness="0" AcceptsReturn="True" TextWrapping="Wrap" Margin="8,24,8,4" CaretBrush="#00FFCC" VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="20*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="35*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="ЖИЛЬЕ" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Housing, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="14" Background="Transparent" BorderThickness="0" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="АРЕНДНАЯ ПЛАТА" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Rent, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="14" Background="Transparent" BorderThickness="0" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A">
                                <Grid>
                                    <Border Style="{StaticResource RedHeader}" HorizontalAlignment="Left" VerticalAlignment="Top" BorderThickness="0,0,2,2" Panel.ZIndex="1">
                                        <TextBlock Text="ОБРАЗ ЖИЗНИ" Style="{StaticResource RedHeaderText}" FontSize="10"/>
                                    </Border>
                                    <TextBox Text="{Binding Lifestyle, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0E0E0" FontSize="14" Background="Transparent" BorderThickness="0" 
                                             AcceptsReturn="True" TextWrapping="Wrap" Margin="6,22,6,4" CaretBrush="#00FFCC" 
                                             VerticalScrollBarVisibility="Auto"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                </Grid>
            </TabItem>

            <TabItem Header="СТР. 3: КИБЕРИМПЛАНТЫ">
                <Grid Margin="0,10,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CyberwareBlocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FF3333" BorderThickness="2" Background="#0A0A0A" Margin="5" Height="150">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="30"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Background="#FF3333" Padding="8,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox IsChecked="{Binding IsInstalled}" VerticalAlignment="Center" Margin="0,0,8,0" Cursor="Hand"/>

                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="#050505" FontWeight="Heavy" FontSize="12" VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="ЗАНЯТО: " Foreground="#050505" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBox Text="{Binding UsedSlots, UpdateSourceTrigger=PropertyChanged}" Width="24" Height="20" Background="#050505" Foreground="#00FFCC" BorderThickness="0" TextAlignment="Center" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0" CaretBrush="#00FFCC"/>
                                                        <TextBlock Text="{Binding SlotsText, StringFormat=' ({0})'}" Foreground="#050505" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <TextBox Grid.Row="1" Text="{Binding OptionsText, UpdateSourceTrigger=PropertyChanged}" 
                                                     Foreground="#E0E0E0" FontSize="13" Background="Transparent" BorderThickness="0" 
                                                     AcceptsReturn="True" TextWrapping="Wrap" Margin="6" CaretBrush="#00FFCC" 
                                                     VerticalScrollBarVisibility="Auto"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal" Margin="0,0,5,0">
            <Button Cursor="Hand" Margin="0,0,10,0" Click="BtnSaveChanges_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="СОХРАНИТЬ" Foreground="#00FFCC" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Cursor="Hand" Click="BtnBackToMenu_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#1A1A1A" BorderBrush="#FF3333" BorderThickness="2,2,2,0" Padding="25,12">
                            <TextBlock Text="ЗАКРЫТЬ ДОСЬЕ" Foreground="#FF3333" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>