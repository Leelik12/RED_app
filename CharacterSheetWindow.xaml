                                        <Button Grid.Column="2" Content="+" Foreground="#050505" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" Cursor="Hand" FontWeight="Bold" FontSize="16" Click="BtnAddInjury_Click" VerticalAlignment="Center"/>
