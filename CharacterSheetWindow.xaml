                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="8,4">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ПУНКТЫ УЛУЧШЕНИЙ" Foreground="#FF3333" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding ImprovementPoints, UpdateSourceTrigger=PropertyChanged}" 
                                                 Foreground="#00FFCC" Background="#111111" BorderBrush="#444444" BorderThickness="1" 
                                                 FontSize="14" FontWeight="Bold" TextAlignment="Center" Padding="2" CaretBrush="#00FFCC"
                                                 PreviewTextInput="NumberValidationTextBox"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="РЕПУТАЦИЯ" Foreground="#FF3333" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Text="{Binding Reputation, UpdateSourceTrigger=PropertyChanged}" 
                                                 Foreground="#00FFCC" Background="#111111" BorderBrush="#444444" BorderThickness="1" 
                                                 FontSize="14" FontWeight="Bold" TextAlignment="Center" Padding="2" CaretBrush="#00FFCC"
                                                 PreviewTextInput="NumberValidationTextBox"/>
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1" Background="#333333" Margin="0,4"/>

