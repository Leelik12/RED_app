<Window x:Class="CyberpunkRED_Generator.RoleAndSkillsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ТЕРМИНАЛ: Навыки" Height="850" Width="1000" Background="#000000" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#00D4B2" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="Foreground" Value="#00D4B2"/>
            <Setter Property="BorderBrush" Value="#00D4B2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#FF4444" BorderThickness="2" Background="#0A0A0A" Padding="20" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ДОСТУПНО ОЧКОВ НАВЫКОВ:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock x:Name="TxtPoints" Text="60" Foreground="#00D4B2" FontSize="26" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="/ 86" Foreground="#555555" FontSize="20" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#00D4B2" BorderThickness="2" Background="#000000" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,15,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="НАВЫК" Foreground="#00D4B2" FontSize="18"/>
                    <TextBlock Grid.Column="1" Text="СТАТ" Foreground="#00D4B2" FontSize="18" TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="УРОВЕНЬ" Foreground="#00D4B2" FontSize="18" TextAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="СУММА" Foreground="#00D4B2" FontSize="18" TextAlignment="Center"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="IcCategories">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,15,25">
                                    <Border Background="#FF4444" Padding="10,5" Margin="0,0,0,10">
                                        <TextBlock Text="{Binding CategoryName}" Foreground="#000000" FontSize="18" FontWeight="Bold"/>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Skills}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding StatName}" Foreground="#757575" VerticalAlignment="Center" TextAlignment="Center"/>

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="-" Style="{StaticResource SmallBtn}" Tag="{Binding}" Click="BtnMinus_Click"/>
                                                        <TextBlock Text="{Binding Level}" Width="40" TextAlignment="Center" VerticalAlignment="Center" Foreground="#FFFFFF" FontSize="18"/>
                                                        <Button Content="+" Style="{StaticResource SmallBtn}" Tag="{Binding}" Click="BtnPlus_Click"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="3" Text="{Binding Total}" Foreground="#00D4B2" FontSize="20" TextAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Button Grid.Row="2" Content="СОХРАНИТЬ И ЗАВЕРШИТЬ ГЕНЕРАЦИЮ" Style="{StaticResource CyberButton}" Height="50" Margin="0,20,0,0"/>
    </Grid>
</Window>