<Window x:Class="CyberpunkRED_Generator.GMScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CyberpunkRED_Generator"
        Title="ТЕРМИНАЛ ГЕЙМ-МАСТЕРА" Height="900" Width="1400" Background="#050505" WindowState="Maximized" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <local:MultiParamConverter x:Key="MultiParamConverter"/>

        <Style x:Key="RedHeader" TargetType="Border">
            <Setter Property="Background" Value="#FF3333"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style x:Key="RedHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3333"/>
            <Setter Property="Foreground" Value="#050505"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FF3333" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF3333"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#050505"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF3333"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#050505"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path x:Name="Arrow" Fill="#00FFCC" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" TextElement.Foreground="{TemplateBinding Foreground}" Margin="6,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}" Background="Transparent" Foreground="{TemplateBinding Foreground}" BorderThickness="0" Margin="6,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Stretch" CaretBrush="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border Background="#0A0A0A" BorderThickness="1" BorderBrush="#FF3333"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#00FFCC"/>
            <Setter Property="BorderBrush" Value="#FF3333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MaxWidth" Value="300"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Border Style="{StaticResource RedHeader}" BorderThickness="0,0,0,2">
                            <TextBlock Text="УПРАВЛЕНИЕ БОЕМ" Style="{StaticResource RedHeaderText}" FontSize="18"/>
                        </Border>

                        <StackPanel Margin="15">
                            <Button Content="ДОБАВИТЬ ПЕРСОНАЖА" Background="#111111" Foreground="#00FFCC" BorderBrush="#00FFCC" BorderThickness="1" Padding="10" FontWeight="Bold" Margin="0,0,0,10" Cursor="Hand" Click="BtnAddPlayer_Click"/>
                            <Button Content="БАЗА ПРОТИВНИКОВ" Style="{StaticResource CyberButton}" Margin="0,0,0,20" Click="BtnOpenEnemyManager_Click"/>

                            <Button Content="СОРТИРОВАТЬ ИНИЦИАТИВУ" Background="#333333" Foreground="#FFFFFF" BorderThickness="0" Padding="10" FontWeight="Bold" Margin="0,0,0,20" Cursor="Hand" Click="BtnSortInitiative_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="15">
                        <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="2" Padding="10" Margin="0,0,0,15">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TxtRoundCounter" Text="РАУНД: 1" Foreground="#00FFCC" FontSize="24" FontWeight="Heavy" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtTimeCounter" Text="Прошло времени: 0 сек." Foreground="#999999" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="СЛЕДУЮЩИЙ ХОД >>" Background="#00FFCC" Foreground="#000000" FontWeight="Heavy" FontSize="22" BorderThickness="0" Padding="15" Cursor="Hand" Click="BtnNextTurn_Click" Margin="0,0,0,10"/>
                        <Button Content="ВЫЙТИ В МЕНЮ" Background="Transparent" Foreground="#FF3333" FontWeight="Bold" Cursor="Hand" Click="BtnExit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#0A0A0A" BorderBrush="#444444" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource RedHeader}" BorderThickness="0,0,0,2" BorderBrush="#444444" Background="#111111">
                        <TextBlock Text="ТРЕКЕР ИНИЦИАТИВЫ" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                        <ItemsControl ItemsSource="{Binding Combatants}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="10" Background="#111111" BorderThickness="2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#333333"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FF3333"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActiveTurn}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#00FFCC"/>
                                                        <Setter Property="Background" Value="#051A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="65"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                    <TextBlock Text="ИНИЦ." Foreground="#777777" FontSize="12" HorizontalAlignment="Center" FontWeight="Bold"/>
                                                    <TextBox Text="{Binding Initiative, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#000000" Foreground="#00FFCC" FontSize="22" FontWeight="Bold" BorderBrush="#444444" BorderThickness="1" TextAlignment="Center" Width="45" Padding="0,2"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,20,0">
                                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="#FFFFFF" FontSize="18" FontWeight="Heavy" BorderThickness="0" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding CombatStatsDisplay}" Foreground="#E0E0E0" FontSize="13" FontWeight="Bold" Margin="0,2,0,6" TextWrapping="Wrap"/>

                                                    <ItemsControl ItemsSource="{Binding DisplaySkills}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Vertical" MaxHeight="100"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" Foreground="#00FFCC" FontSize="13" FontWeight="Bold" Margin="0,0,15,2"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <TextBlock Text="{Binding ActionPenalty, StringFormat='ШТРАФ К ДЕЙСТВИЯМ: -{0}'}" Foreground="#FF3333" FontSize="13" FontWeight="Bold" Margin="0,4,0,0" Visibility="{Binding PenaltyVis}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,5,20,0">
                                                    <TextBlock Text="ЗДОРОВЬЕ (ПЗ)" Foreground="#777777" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                        <Button Content="+" Background="#FF3333" Foreground="Black" Width="22" Height="22" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnHeal_Click" ToolTip="Исцелить 1 ПЗ"/>
                                                        <TextBox Text="{Binding CurrentHP, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="Transparent" Foreground="#FF3333" FontSize="20" FontWeight="Bold" BorderThickness="0" TextAlignment="Center" Width="38"/>
                                                        <TextBlock Text="/" Foreground="#777777" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="2,0"/>
                                                        <TextBox Text="{Binding MaxHP, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="Transparent" Foreground="#777777" FontSize="20" FontWeight="Bold" BorderThickness="0" TextAlignment="Center" Width="38"/>
                                                        <Button Content="-" Background="#FF3333" Foreground="Black" Width="22" Height="22" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnDamage_Click" ToolTip="Нанести 1 урон"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Top" Margin="0,5,20,0">
                                                    <TextBlock Text="ОС (ГОЛОВА)" Foreground="#777777" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,8">
                                                        <TextBox Text="{Binding HeadArmor, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="Transparent" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" BorderThickness="0" TextAlignment="Center" Width="35"/>
                                                        <Button Content="-1 ОС" Background="#333333" Foreground="#00FFCC" BorderThickness="0" Padding="6,2" FontWeight="Bold" Cursor="Hand" Tag="{Binding}" Click="BtnAblateHead_Click"/>
                                                    </StackPanel>

                                                    <TextBlock Text="ОС (ТЕЛО)" Foreground="#777777" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                        <TextBox Text="{Binding BodyArmor, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="Transparent" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" BorderThickness="0" TextAlignment="Center" Width="35"/>
                                                        <Button Content="-1 ОС" Background="#333333" Foreground="#00FFCC" BorderThickness="0" Padding="6,2" FontWeight="Bold" Cursor="Hand" Tag="{Binding}" Click="BtnAblateBody_Click"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" VerticalAlignment="Top" Margin="0,5,15,0">
                                                    <TextBlock Text="{Binding CurrentMove, StringFormat='ТЕКУЩЕЕ СКО: {0}'}" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding CurrentDeathSave, StringFormat='СПАСБРОСОК: {0}'}" Foreground="#FF3333" FontSize="14" FontWeight="Bold" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="5" Content="X" Background="Transparent" Foreground="#FF3333" BorderThickness="0" FontWeight="Bold" FontSize="20" Cursor="Hand" VerticalAlignment="Top" Tag="{Binding}" Click="BtnRemoveCombatant_Click" Margin="0,0,5,0"/>
                                            </Grid>

                                            <Grid x:Name="MiddleBlock" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="ОРУЖИЕ:" Foreground="#999999" FontSize="10" FontWeight="Bold"/>
                                                    <TextBox Text="{Binding Weapons, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#00FFCC" BorderBrush="#333" BorderThickness="1" Padding="4" TextWrapping="Wrap" AcceptsReturn="True" Height="70" VerticalScrollBarVisibility="Auto"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                                    <TextBlock Text="СНАРЯЖЕНИЕ / БРОНЯ:" Foreground="#999999" FontSize="10" FontWeight="Bold"/>
                                                    <TextBox Text="{Binding Gear, UpdateSourceTrigger=PropertyChanged}" Background="#050505" Foreground="#E0E0E0" BorderBrush="#333" BorderThickness="1" Padding="4" TextWrapping="Wrap" AcceptsReturn="True" Height="70" VerticalScrollBarVisibility="Auto"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                                    <TextBlock Text="КИБЕРИМПЛАНТЫ:" Foreground="#999999" FontSize="10" FontWeight="Bold"/>
                                                    <ScrollViewer Height="70" VerticalScrollBarVisibility="Auto" Background="#050505" BorderBrush="#333" BorderThickness="1" Padding="2">
                                                        <ItemsControl ItemsSource="{Binding ParsedCyberware}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="1" Margin="0,0,0,4" Padding="4" ToolTip="{Binding TooltipText}" ToolTipService.InitialShowDelay="150" Cursor="Help">
                                                                        <TextBlock Text="{Binding Name}" Foreground="#00FFCC" FontSize="11" FontWeight="Bold" TextWrapping="Wrap"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel x:Name="BottomBlock">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="КРИТИЧЕСКИЕ ТРАВМЫ:" Foreground="#FF3333" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableInjuries}" SelectedItem="{Binding SelectedInjuryToAdd, UpdateSourceTrigger=PropertyChanged}" Background="#0A0A0A" Foreground="#FF3333" Height="22"/>
                                                    <Button Grid.Column="2" Content="+ ДОБАВИТЬ" Background="#FF3333" Foreground="#000" FontWeight="Bold" Padding="10,0" Margin="10,0,0,0" Cursor="Hand" Tag="{Binding}" Click="BtnAddCritToCombatant_Click"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding ActiveInjuries}" Margin="0,5,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#FF3333" BorderThickness="0,0,0,1" Padding="2" Margin="0,0,0,2" ToolTip="{Binding TooltipText}" ToolTipService.InitialShowDelay="150" Cursor="Help">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Name}" Foreground="#FF3333" FontSize="12" VerticalAlignment="Center"/>
                                                                    <Button Grid.Column="1" Content="Удалить" Background="Transparent" Foreground="#999" BorderThickness="0" Cursor="Hand" FontSize="11" Click="BtnRemoveCritFromCombatant_Click">
                                                                        <Button.Tag>
                                                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                                                <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                                <Binding Path="."/>
                                                                            </MultiBinding>
                                                                        </Button.Tag>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter TargetName="MiddleBlock" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="BottomBlock" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="EnemyManagerOverlay" Background="#E5050505" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="#0A0A0A" BorderBrush="#FF3333" BorderThickness="2" Width="1200" Height="850" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource RedHeader}">
                        <Grid>
                            <TextBlock Text="БАЗА ПРОТИВНИКОВ И ГЕНЕРАТОР" Style="{StaticResource RedHeaderText}" HorizontalAlignment="Left"/>
                            <Button Content="X" Foreground="#050505" Background="Transparent" BorderThickness="0" FontWeight="Bold" FontSize="20" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="BtnCloseEnemyManager_Click"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="ДОСТУПНЫЕ ПРЕСЕТЫ" Foreground="#00FFCC" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AvailableEnemies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111111" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,5" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" Foreground="#FFFFFF" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding HP, StringFormat='ПЗ: {0}'}" Foreground="#FF3333" FontSize="12"/>
                                                        <TextBlock Text="Боевой Номер (Упрощенный)" Foreground="#00FFCC" FontSize="11" Visibility="{Binding IsCNVis}"/>
                                                        <TextBlock Text="Полные Статы (Развернутый)" Foreground="#E0E0E0" FontSize="11" Visibility="{Binding IsFullVis}"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1" Content="РЕДАКТ." Foreground="#E0E0E0" Background="#333333" BorderThickness="0" Padding="10,5" Margin="0,0,5,0" FontWeight="Bold" Cursor="Hand" Tag="{Binding}" Click="BtnEditEnemyPreset_Click" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="2" Content="УДАЛИТЬ" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Padding="10,5" Margin="0,0,5,0" FontWeight="Bold" Cursor="Hand" Tag="{Binding}" Click="BtnDeleteEnemyPreset_Click" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="3" Content="ДОБАВИТЬ" Foreground="#000000" Background="#00FFCC" BorderThickness="0" Padding="10,5" FontWeight="Bold" Cursor="Hand" Tag="{Binding}" Click="BtnSpawnEnemy_Click" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Column="2" BorderBrush="#FF3333" BorderThickness="1" Background="#111111" Padding="15">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="СОЗДАТЬ НОВОГО ВРАГА" Foreground="#FF3333" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                    <TextBlock Text="Имя / Тип (напр. 'Бустергангер'):" Foreground="#999999" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtGenName" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" FontSize="14" Padding="5" Margin="0,0,0,15"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <RadioButton x:Name="RbGenCN" Content="Боевой Номер (БН)" Foreground="#00FFCC" FontSize="14" FontWeight="Bold" IsChecked="True" Checked="GenMode_Changed" Margin="0,0,20,0"/>
                                        <RadioButton x:Name="RbGenFull" Content="Полный Расчет (Статы + Навыки)" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" Checked="GenMode_Changed"/>
                                    </StackPanel>

                                    <Grid x:Name="PanelGenCN" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Боевой Номер (БН):" Foreground="#00FFCC" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenCN" Text="12" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#00FFCC" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Спасбросок смерти (База):" Foreground="#FF3333" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenDeathSaveCN" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#FF3333" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="СКО (Move):" Foreground="#FFFFFF" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenMove" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel x:Name="PanelGenFull" Visibility="Collapsed" Margin="0,0,0,15">
                                        <TextBlock Text="ХАРАКТЕРИСТИКИ:" Foreground="#E0E0E0" Margin="0,0,0,5" FontWeight="Bold"/>
                                        <UniformGrid Columns="5" Margin="0,0,0,15">
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ИНТ" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StINT" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="РЕА" Foreground="#0FC" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StREF" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#0FC" FontWeight="Bold" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ЛВК" Foreground="#0FC" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StDEX" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#0FC" FontWeight="Bold" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ТЕХ" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StTECH" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ХАР" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StCOOL" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ВОЛЯ" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StWILL" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="УДЧ" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StLUCK" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="СКО" Foreground="#FFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StMOVE" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" FontWeight="Bold" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ТЕЛ" Foreground="#F33" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StBODY" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#F33" FontWeight="Bold" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="ЭМП" Foreground="#777" FontSize="11" HorizontalAlignment="Center"/>
                                                <TextBox x:Name="StEMP" Text="5" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050" Foreground="#FFF" TextAlignment="Center" BorderBrush="#333"/>
                                            </StackPanel>
                                        </UniformGrid>

                                        <TextBlock Text="ДОБАВИТЬ НАВЫК:" Foreground="#E0E0E0" Margin="0,0,0,5" FontWeight="Bold"/>
                                        <CheckBox x:Name="ChkSkillIsTotal" Content="Указать финальный результат (Навык + СТАТ)" Foreground="#00FFCC" FontSize="12" Margin="0,0,0,5" Cursor="Hand"/>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="CbGenSkills" ItemsSource="{Binding AllSkillNames}" Background="#0A0A0A" Foreground="#FFF" BorderBrush="#444" Height="26"/>
                                            <TextBox x:Name="TxtGenSkillLevel" Grid.Column="2" Text="10" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#0A0A0A" Foreground="#0FC" FontWeight="Bold" TextAlignment="Center" BorderBrush="#444" Height="26"/>
                                            <Button Grid.Column="4" Content="+" Foreground="#0FC" Background="Transparent" FontWeight="Bold" FontSize="18" Cursor="Hand" BorderThickness="0" Click="BtnAddGenSkill_Click"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding NewEnemySkills}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="2" Margin="0,2">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat='Ур: {0}'}" Foreground="#0FC" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="2" Content="x" Foreground="#F33" Background="Transparent" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveGenSkill_Click"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ОС Головы:" Foreground="#999999" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenHead" Text="7" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="ОС Тела:" Foreground="#999999" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenBody" Text="7" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Здоровье (ПЗ):" Foreground="#999999" Margin="0,0,0,5"/>
                                            <TextBox x:Name="TxtGenHP" Text="30" PreviewTextInput="NumberValidationTextBox" TextChanged="NumberLimitTextBox_TextChanged" Background="#050505" Foreground="#FF3333" BorderBrush="#444444" BorderThickness="1" FontSize="14" FontWeight="Bold" Padding="5" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Оружие:" Foreground="#999999" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtGenWeapons" Background="#050505" Foreground="#FFFFFF" BorderBrush="#444444" BorderThickness="1" FontSize="12" Margin="0,0,0,10" Padding="5" Height="40" AcceptsReturn="True" TextWrapping="Wrap"/>

                                    <TextBlock Text="Снаряжение:" Foreground="#999999" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtGenGear" Background="#050505" Foreground="#E0E0E0" BorderBrush="#444444" BorderThickness="1" FontSize="12" Margin="0,0,0,10" Padding="5" Height="40" AcceptsReturn="True" TextWrapping="Wrap"/>

                                    <TextBlock Text="КИБЕРИМПЛАНТЫ:" Foreground="#999999" Margin="0,0,0,5"/>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="CbGenCyber" ItemsSource="{Binding AllCyberwareNames}" IsEditable="True" Background="#050505" Foreground="#FFF" BorderBrush="#444444" BorderThickness="1" Height="26" Padding="5,0"/>
                                        <Button Grid.Column="2" Content="+" Foreground="#00FFCC" Background="Transparent" FontWeight="Bold" FontSize="18" Cursor="Hand" BorderThickness="0" Click="BtnAddGenCyber_Click"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding NewEnemyCyberware}" Margin="0,0,0,15">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A1A" BorderBrush="#00FFCC" BorderThickness="1" Padding="4" Margin="0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding}" Foreground="#00FFCC" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="1" Content="x" Foreground="#FF3333" Background="Transparent" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnRemoveGenCyber_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="СОХРАНИТЬ ПРЕСЕТ В БАЗУ" Style="{StaticResource CyberButton}" Click="BtnSaveNewEnemy_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>

    </Grid>
</Window>