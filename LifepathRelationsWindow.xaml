<Window x:Class="CyberpunkRED_Generator.LifepathRelationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ТЕРМИНАЛ: Связи" Height="800" Width="1100" Background="#000000" WindowStartupLocation="CenterScreen" FontFamily="Consolas">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#000000"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#00D4B2" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="Foreground" Value="#00D4B2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,8"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF4444"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#000000"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF4444"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#000000"/>
            </Style.Resources>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#00D4B2"/>
            <Setter Property="Background" Value="#0A0A0A"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path Fill="#00D4B2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Data="M 0 0 L 5 5 L 10 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" TextElement.Foreground="{TemplateBinding Foreground}" Margin="10,8,30,8" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="300">
                                    <Border Background="#000000" BorderThickness="2" BorderBrush="#FF4444"/>
                                    <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#FF4444"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <Border BorderBrush="#FF4444" BorderThickness="2" Background="#000000" Padding="20" Margin="0,0,15,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ИНТЕРФЕЙС ГЕНЕРАЦИИ :: СВЯЗИ" FontSize="22" Margin="0,0,0,20"/>
                <Button Grid.Row="1" Content="АЛГОРИТМ РАНДОМА (1D10 - 7)" Style="{StaticResource CyberButton}" Click="BtnRandomize_Click" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                    <StackPanel Margin="0,0,15,0">

                        <TextBlock Text="Количество друзей:" Foreground="#999999" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CbCountFriends" SelectionChanged="CountChanged">
                            <ComboBoxItem Content="0" Tag="0"/>
                            <ComboBoxItem Content="1" Tag="1"/>
                            <ComboBoxItem Content="2" Tag="2"/>
                            <ComboBoxItem Content="3" Tag="3"/>
                        </ComboBox>

                        <StackPanel x:Name="PanelFriends" Visibility="Collapsed" Margin="10,0,0,10">
                            <StackPanel x:Name="SlotF1">
                                <TextBlock Text="Друг 1:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbF1" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotF2">
                                <TextBlock Text="Друг 2:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbF2" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotF3">
                                <TextBlock Text="Друг 3:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbF3" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Количество врагов:" Foreground="#999999" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CbCountEnemies" SelectionChanged="CountChanged">
                            <ComboBoxItem Content="0" Tag="0"/>
                            <ComboBoxItem Content="1" Tag="1"/>
                            <ComboBoxItem Content="2" Tag="2"/>
                            <ComboBoxItem Content="3" Tag="3"/>
                        </ComboBox>

                        <StackPanel x:Name="PanelEnemies" Visibility="Collapsed" Margin="10,0,0,10">
                            <StackPanel x:Name="SlotE1" Margin="0,0,0,15">
                                <TextBlock Text="ВРАГ 1" Foreground="#FF4444" Margin="0,0,0,5" FontSize="18"/>
                                <TextBlock Text="Кто он:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE1Who" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Причина вражды:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE1Cause" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Кто кого ненавидит:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE1Hate" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Что они сделают:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE1Action" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotE2" Margin="0,0,0,15">
                                <TextBlock Text="ВРАГ 2" Foreground="#FF4444" Margin="0,0,0,5" FontSize="18"/>
                                <TextBlock Text="Кто он:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE2Who" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Причина вражды:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE2Cause" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Кто кого ненавидит:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE2Hate" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Что они сделают:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE2Action" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotE3" Margin="0,0,0,15">
                                <TextBlock Text="ВРАГ 3" Foreground="#FF4444" Margin="0,0,0,5" FontSize="18"/>
                                <TextBlock Text="Кто он:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE3Who" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Причина вражды:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE3Cause" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Кто кого ненавидит:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE3Hate" SelectionChanged="UpdateLog"/>
                                <TextBlock Text="Что они сделают:" Foreground="#999999"/>
                                <ComboBox x:Name="CbE3Action" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Количество трагических романов:" Foreground="#999999" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CbCountLove" SelectionChanged="CountChanged">
                            <ComboBoxItem Content="0" Tag="0"/>
                            <ComboBoxItem Content="1" Tag="1"/>
                            <ComboBoxItem Content="2" Tag="2"/>
                            <ComboBoxItem Content="3" Tag="3"/>
                        </ComboBox>

                        <StackPanel x:Name="PanelLove" Visibility="Collapsed" Margin="10,0,0,10">
                            <StackPanel x:Name="SlotL1">
                                <TextBlock Text="Роман 1:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbL1" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotL2">
                                <TextBlock Text="Роман 2:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbL2" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                            <StackPanel x:Name="SlotL3">
                                <TextBlock Text="Роман 3:" Foreground="#00D4B2"/>
                                <ComboBox x:Name="CbL3" SelectionChanged="UpdateLog"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Column="1" BorderBrush="#00D4B2" BorderThickness="2" Background="#000000" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ДОСЬЕ: СОЦИАЛЬНЫЕ СВЯЗИ" Foreground="#00D4B2" FontSize="20" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtTerminalLog" Foreground="#E0E0E0" TextWrapping="Wrap" FontSize="15" LineHeight="24" Text="> СБОР ДАННЫХ..."/>
                </ScrollViewer>

                <Button Grid.Row="2" Content="ПРОДОЛЖИТЬ [ГОТОВО]" Style="{StaticResource CyberButton}" Height="50" FontSize="18" Margin="0,20,0,0" Click="Button_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>