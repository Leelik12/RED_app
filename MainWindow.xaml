<Window x:Class="CyberpunkRED_Generator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyberpunk RED - Главное меню" Height="500" Width="700" Background="#1a1a1a" WindowStartupLocation="CenterScreen">

    <Viewbox Stretch="Uniform">
        <Grid Width="700" Height="500">
            <StackPanel VerticalAlignment="Center" Margin="40">
                <TextBlock Text="CYBERPUNK RED" Foreground="Red" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Content="1. Генерация персонажа" Height="55" FontSize="20" Margin="0,10" Background="Red" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnGenerate_Click"/>
                <Button Content="2. Лист персонажа" Height="55" FontSize="20" Margin="0,10" Background="Red" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnLoadCharacter_Click"/>
                <Button Content="3. Экран Гейм-мастера" Height="55" FontSize="20" Margin="0,10" Background="Red" Foreground="White" FontWeight="Bold" Cursor="Hand" Click="BtnOpenGMScreen_Click"/>
            </StackPanel>
        </Grid>
    </Viewbox>
</Window>